        {
          "name": "Google OAuth Connect (App Login)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google/connect",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "connect"]
            },
            "description": "Returns Google OAuth URL for app login/signup callback flow."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.collectionVariables.set('googleAuthUrl', body.url);",
                  "try { var parsed = new URL(body.url); var state = parsed.searchParams.get('state'); if (state) pm.collectionVariables.set('googleAuthState', state); } catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Google OAuth Callback (App Login)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google/callback?code={{googleAuthCode}}&state={{googleAuthState}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "callback"],
              "query": [
                { "key": "code", "value": "{{googleAuthCode}}" },
                { "key": "state", "value": "{{googleAuthState}}" }
              ]
            },
            "description": "Exchanges Google code+state and returns PersonalAPI access token."
