  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://127.0.0.1:8000');",
          "}",
          "if (!pm.collectionVariables.get('apiPrefix')) {",
          "  pm.collectionVariables.set('apiPrefix', 'v1');",
          "}",
          "var _prefix = pm.collectionVariables.get('apiPrefix') || 'v1';",
          "_prefix = _prefix.replace(/^\\/+|\\/+$/g, '');",
          "pm.collectionVariables.set('apiPrefix', _prefix);",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
