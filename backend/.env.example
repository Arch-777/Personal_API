APP_NAME=PersonalAPI
APP_VERSION=0.1.0
API_PREFIX=/v1
DEBUG=true
ENABLE_INLINE_SYNC_FALLBACK=true

CORS_ORIGINS=http://localhost:3000
FRONTEND_APP_URL=http://127.0.0.1:3000
USER_DATA_ROOT=storage

DATABASE_URL=postgresql+psycopg://postgres:localpass@localhost:5432/personalapi
DATABASE_SSL_MODE=prefer
DATABASE_CONNECT_TIMEOUT=10
DATABASE_STARTUP_CHECK_REQUIRED=true
DATABASE_STARTUP_CHECK_RETRIES=1
DATABASE_STARTUP_CHECK_RETRY_DELAY_SECONDS=1.5
REDIS_URL=redis://localhost:6379/0
AUTO_SYNC_ENABLED=true

# Optional local LLM for RAG answer generation (Ollama + Qwen)
RAG_LLM_ENABLED=false
RAG_LLM_PROVIDER=ollama
RAG_LLM_BASE_URL=http://localhost:11434
RAG_LLM_MODEL=qwen2.5:1.5b
RAG_LLM_TIMEOUT_SECONDS=45
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_MAX_TOKENS=512
RAG_LLM_SYSTEM_PROMPT=
RAG_LLM_FAILOVER_ENABLED=false
RAG_LLM_FAILOVER_PROVIDER=ollama
RAG_LLM_FAILOVER_BASE_URL=
RAG_LLM_FAILOVER_MODEL=
RAG_EMBEDDING_PROVIDER=fastembed
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_EMBEDDING_DIMENSIONS=1536
RAG_GROUNDING_MIN_TOP_SCORE=0.55
RAG_GROUNDING_MIN_AVG_SCORE=0.42
RAG_SEMANTIC_CANDIDATE_LIMIT=120
RAG_LEXICAL_CANDIDATE_LIMIT=120
RAG_RRF_K=20
RAG_RRF_SEMANTIC_WEIGHT=0.65
RAG_RRF_LEXICAL_WEIGHT=0.35
RAG_RRF_BOOST=2.5
RAG_CHUNK_MAX_TOKENS=240
RAG_CHUNK_OVERLAP_TOKENS=40
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MAX_VARIANTS=3
RAG_RERANKER_ENABLED=true
RAG_RERANKER_TOP_N=24
RAG_RERANKER_WEIGHT=0.35
RAG_NEIGHBOR_CHUNK_ENABLED=true
RAG_NEIGHBOR_CHUNK_WINDOW=1
RAG_CONTEXT_MAX_TOKENS=1200
RAG_CITATION_CLAIM_VERIFICATION_ENABLED=true
RAG_CITATION_CLAIM_MIN_TOKEN_OVERLAP=0.12
RAG_CACHE_ENABLED=true
RAG_QUERY_EMBEDDING_CACHE_TTL_SECONDS=300
RAG_QUERY_EMBEDDING_CACHE_MAX_SIZE=2048
RAG_RETRIEVAL_CACHE_TTL_SECONDS=120
RAG_RETRIEVAL_CACHE_MAX_SIZE=1024
RAG_LLM_CIRCUIT_BREAKER_ENABLED=true
RAG_LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
RAG_LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# Azure PostgreSQL (Flexible Server) example
# DATABASE_URL=postgresql+psycopg://personalapi_admin:YOUR_PASSWORD@your-server.postgres.database.azure.com:5432/personalapi
# DATABASE_SSL_MODE=require

SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_CLIENT_IDS=96836861331-9nr0169t0svo5r4g87kj68p8nm31kp0o.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/v1/connectors/google/callback
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo

# Spotify OAuth — get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/v1/connectors/spotify/callback

# Slack OAuth — create an app at https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://127.0.0.1:8000/v1/connectors/slack/callback

# GitHub OAuth app — create at https://github.com/settings/developers


# Notion integration — get from https://www.notion.so/my-integrations
# For full OAuth: set NOTION_CLIENT_ID + NOTION_CLIENT_SECRET and use GET /v1/connectors/notion/connect
# For quick dev testing: use POST /v1/connectors/notion/token with your internal integration token
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://127.0.0.1:8000/v1/connectors/notion/callback

